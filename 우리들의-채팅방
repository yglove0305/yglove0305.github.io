<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>실시간 채팅</title>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; }
        #messages { height: 300px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }
        #nicknameInput, #messageInput { width: 80%; padding: 10px; }
        #sendButton, #saveNickname { padding: 10px; }
    </style>
</head>
<body>

    <h1>실시간 채팅</h1>
    <div id="nicknameSection">
        <input type="text" id="nicknameInput" placeholder="닉네임 입력">
        <button id="saveNickname">저장</button>
    </div>

    <div class="chat-container" style="display: none;">
        <div id="messages"></div>
        <input type="text" id="messageInput" placeholder="메시지를 입력하세요">
        <button id="sendButton">전송</button>
    </div>

    <script>
        const socket = new WebSocket("ws://localhost:8080");

        const nicknameInput = document.getElementById("nicknameInput");
        const saveNicknameButton = document.getElementById("saveNickname");
        const messageInput = document.getElementById("messageInput");
        const sendButton = document.getElementById("sendButton");
        const messagesDiv = document.getElementById("messages");
        const chatContainer = document.querySelector(".chat-container");
        const nicknameSection = document.getElementById("nicknameSection");

        // 닉네임 저장 및 표시
        saveNicknameButton.addEventListener("click", () => {
            const nickname = nicknameInput.value.trim();
            if (nickname) {
                localStorage.setItem("nickname", nickname);
                nicknameSection.style.display = "none";
                chatContainer.style.display = "block";
            }
        });

        // 닉네임이 이미 설정되어 있으면 바로 채팅 화면 표시
        window.onload = () => {
            const savedNickname = localStorage.getItem("nickname");
            if (savedNickname) {
                nicknameSection.style.display = "none";
                chatContainer.style.display = "block";
            }
        };

        // 메시지 수신 처리
        socket.onmessage = (event) => {
            const messageElement = document.createElement("div");
            messageElement.textContent = event.data;
            messagesDiv.appendChild(messageElement);
        };

        // 메시지 전송
        sendButton.addEventListener("click", () => {
            const message = messageInput.value.trim();
            const nickname = localStorage.getItem("nickname") || "익명";
            if (message) {
                socket.send(nickname + ": " + message);
                messageInput.value = "";
            }
        });

    </script>

</body>
</html>
